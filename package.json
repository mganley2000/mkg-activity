{
  "name": "mkg-activity",
  "version": "1.0.0",
  "private": true,
  "description": "Easy work activity logging application backed by sqlite",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/assets/app.js --platform=browser",
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "esbuild src/client/main.ts --bundle --outfile=public/assets/app.js --platform=browser --watch",
    "start": "node dist/index.js",
    "prestart": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "eta": "^3.5.0",
    "express": "^4.21.0",
    "zod": "^3.23.8",
    "dompurify": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
